#include <stdio.h>
int arraySum(int arr[], int size);
int main() {
    int n, i;
    printf("Enter number of elements: ");
    scanf("%d", &n);
    int arr[n];
    printf("Enter %d elements:\n", n);
    for (i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }
    int sum = arraySum(arr, n);
    printf("Sum of array elements = %d\n", sum);
    return 0;
}
int arraySum(int arr[], int size) {
    int total = 0;
    for (int i = 0; i < size; i++) {
        total += arr[i];
    }
    return total;
}
